---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate, isPublic } from '../../lib/content';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter(isPublic);
  return posts.map((post) => ({ params: { slug: post.data.slug }, props: { post } }));
}

interface Props { post: CollectionEntry<'blog'>; }
const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="article-shell stack-lg">
    <header class="stack">
      <p class="eyebrow">{post.data.category ?? 'Blog'} · {formatDate(post.data.updated)}</p>
      <h1>{post.data.title}</h1>
      <p class="lede">{post.data.description}</p>
      <div class="tag-list">{post.data.tags.map((tag) => <a class="tag" href={`/tags/#${encodeURIComponent(tag)}`}>{tag}</a>)}</div>
    </header>
    <div class="prose"><Content /></div>
  </article>
</BaseLayout>
