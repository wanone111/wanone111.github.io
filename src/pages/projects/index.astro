---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import { byNewest, formatDate, isPublic } from '../../lib/content';

const projects = (await getCollection('projects')).filter(isPublic).sort(byNewest);
---

<BaseLayout title="项目" description="Wanone 的嵌入式、机器人、FPGA 与边缘 AI 项目。">
  <div class="stack-xl">
    <PageIntro eyebrow="Projects · systems" title="项目系统" description="不堆叠概念卡片；只展示真实目标、系统结构、关键实现和验证结果。" />
    {projects.length > 0 ? (
      <div class="project-list">
        {projects.map((project, index) => (
          <article class="project-feature">
            <div class="project-feature__index">{String(index + 1).padStart(2, '0')}</div>
            <div class="project-feature__body stack">
              <p class="eyebrow">{project.data.category ?? 'Engineering system'} · {formatDate(project.data.updated)}</p>
              <h2>{project.data.title}</h2>
              <p class="lede">{project.data.description}</p>
              <div class="tag-list">{project.data.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
            </div>
            <a class="button secondary" href={`/projects/${project.data.slug}/`}>查看项目</a>
          </article>
        ))}
      </div>
    ) : <div class="empty-state">暂无公开项目。</div>}
  </div>
</BaseLayout>

<style>
  .project-feature { display: grid; grid-template-columns: 1fr 7fr auto; gap: var(--space-7); align-items: start; border: 1px solid var(--color-border-strong); border-radius: var(--radius-xl); padding: clamp(1.5rem, 5vw, 4rem); background: linear-gradient(145deg, var(--color-accent-soft), var(--color-surface) 48%); box-shadow: var(--shadow-card); }
  .project-feature__index { color: var(--color-accent); font: 850 clamp(2rem, 5vw, 4.5rem)/1 var(--font-mono); }
  .project-feature__body h2 { max-width: 18ch; }
  .project-feature__body .lede { max-width: 48rem; }
  @media (max-width: 48rem) { .project-feature { grid-template-columns: 1fr; gap: var(--space-5); } }
</style>
