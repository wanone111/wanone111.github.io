---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleRow from '../components/ArticleRow.astro';
import ProjectShowcaseCard from '../components/ProjectShowcaseCard.astro';
import { byNewest, formatDate, isPublic } from '../lib/content';

const posts = (await getCollection('blog')).filter(isPublic).sort(byNewest);
const featuredPost = posts.find((entry) => entry.data.featured);
const recentPosts = posts.filter((entry) => entry.id !== featuredPost?.id).slice(0, featuredPost ? 3 : 4);
const projects = (await getCollection('projects')).filter(isPublic).sort(byNewest);
const featuredProjects = projects
  .filter((entry) => entry.data.featured)
  .sort((a, b) => {
    const order = (a.data.featured_order ?? Number.MAX_SAFE_INTEGER) - (b.data.featured_order ?? Number.MAX_SAFE_INTEGER);
    return order || byNewest(a, b);
  });
const selectedProjects = (featuredProjects.length > 0 ? featuredProjects : projects).slice(0, 3);
const siteUrl = Astro.site ?? new URL('https://wanone111.github.io');
const homeJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: '万志成',
    alternateName: 'Wanone',
    url: siteUrl.href,
    sameAs: ['https://github.com/wanone111'],
    knowsAbout: ['嵌入式系统', '机器人系统', 'ROS 2', 'PX4', 'FPGA', 'PYNQ', '边缘 AI'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Wanone',
    url: siteUrl.href,
    inLanguage: 'zh-CN',
    description: '个人工程档案、技术编辑部与数字知识花园。',
  },
];
---

<BaseLayout title="Wanone" description="万志成的个人工程档案，记录嵌入式、机器人、FPGA 与边缘 AI 实践。" contentType="首页" jsonLd={homeJsonLd}>
  <div class="home-flow">
    <section class="home-intro editorial-grid" aria-labelledby="intro-title">
      <div class="home-hero__copy">
        <p class="section-marker"><span>01</span> / INTRO</p>
        <h1 id="intro-title">你好，我是<strong>万志成</strong>。我构建嵌入式、机器人与边缘 AI 系统。</h1>
        <p class="home-hero__summary">我关注 ROS 2 / PX4、FPGA 视频链路和端侧推理，并记录其中的工程判断与调试过程。</p>
        <div class="home-hero__actions" aria-label="主要入口">
          <a class="button" href="/projects/">查看项目</a>
          <a class="button secondary" href="/resume/">阅读简历</a>
        </div>
        <div class="home-hero__secondary" aria-label="更多个人信息">
          <a href="https://github.com/wanone111" rel="me">联系我</a>
          <a href="/notes/">工程笔记</a>
          <a href="/about/">关于</a>
        </div>
      </div>
    </section>

    <section class="home-section systems-section" aria-labelledby="systems-title">
      <div class="home-section__heading">
        <div><p class="section-marker"><span>02</span> / SELECTED WORK</p><h2 id="systems-title">代表项目</h2></div>
      </div>
      {selectedProjects.length > 0 ? (
        <div class="project-list">
          {selectedProjects.map((project, index) => (
            <ProjectShowcaseCard
              index={index}
              title={project.data.title}
              description={project.data.description}
              category={project.data.category}
              updated={formatDate(project.data.updated)}
              tags={project.data.tags}
              href={`/projects/${project.data.slug}/`}
              cover={project.data.cover}
              status={project.data.status}
              role={project.data.role}
              result={project.data.result}
              validation={project.data.validation}
            />
          ))}
        </div>
      ) : <div class="empty-state">暂无公开项目。</div>}
    </section>

    <section class="home-section" aria-labelledby="notes-title">
      <div class="home-section__heading">
        <div><p class="section-marker"><span>03</span> / FIELD NOTES</p><h2 id="notes-title">工程笔记</h2></div>
        <a class="text-link" href="/notes/">浏览全部 {posts.length} 篇</a>
      </div>
      {posts.length > 0 ? (
        <div class="notes-layout">
          {featuredPost && (
            <a class="featured-note" href={`/notes/${featuredPost.data.slug}/`}>
              <p class="eyebrow">FEATURED · {featuredPost.data.category}</p>
              <h3>{featuredPost.data.title}</h3>
              <p>{featuredPost.data.description}</p>
              <span>{formatDate(featuredPost.data.updated)} · 阅读精选笔记 →</span>
            </a>
          )}
          <div class="recent-notes">
            {recentPosts.map((post) => (
              <ArticleRow href={`/notes/${post.data.slug}/`} title={post.data.title} description={post.data.description} category={post.data.category} meta={formatDate(post.data.updated)} />
            ))}
          </div>
        </div>
      ) : <div class="empty-state">暂无公开文章。</div>}
    </section>

    <section class="home-section" aria-labelledby="knowledge-title">
      <div class="home-section__heading">
        <div><p class="section-marker"><span>04</span> / KNOWLEDGE</p><h2 id="knowledge-title">知识路径</h2></div>
      </div>
      <div class="knowledge-list">
        <a class="knowledge-path knowledge-path--yellow" href="/knowledge/embedded/"><span>01</span><div><h3>嵌入式与通信</h3><p>STM32、总线协议、调试流程与工程实践。</p></div><b aria-hidden="true">→</b></a>
        <a class="knowledge-path knowledge-path--blue" href="/knowledge/robotics/"><span>02</span><div><h3>机器人系统</h3><p>ROS 2、PX4、仿真与控制系统。</p></div><b aria-hidden="true">→</b></a>
        <a class="knowledge-path knowledge-path--purple" href="/knowledge/fpga-edge-ai/"><span>03</span><div><h3>FPGA 与边缘 AI</h3><p>FPGA、PYNQ、视频链路与边缘推理。</p></div><b aria-hidden="true">→</b></a>
        <a class="knowledge-path knowledge-path--green" href="/knowledge/linux-tools/"><span>04</span><div><h3>Linux 与工程工具</h3><p>开发环境、Git、WSL 和工程化流程。</p></div><b aria-hidden="true">→</b></a>
      </div>
    </section>

    <section class="home-section about-section" aria-labelledby="about-title">
      <div class="home-section__heading">
        <div><p class="section-marker"><span>05</span> / ABOUT</p><h2 id="about-title">关于我</h2></div>
      </div>
      <div class="about-section__body">
        <p>我重视可复现测试、日志记录和文档沉淀，并通过构建状态、运行日志、通信记录和对照实验逐步定位复杂软硬件系统中的问题。</p>
        <div class="about-section__links">
          <a class="text-link" href="/about/">完整介绍</a>
          <a class="text-link" href="/resume/">个人简历</a>
          <a class="text-link" href="https://github.com/wanone111" rel="me">GitHub</a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .home-flow { display: grid; }
  .home-intro { min-height: min(34rem, calc(100vh - var(--header-height))); padding-block: clamp(3rem, 8vw, 7rem); }
  .home-hero__copy { grid-column: 1 / span 10; display: grid; gap: clamp(1rem, 2.4vw, 1.8rem); }
  .home-intro h1 { max-width: 20ch; font-size: clamp(2.4rem, 5.8vw, 5.8rem); font-weight: 520; line-height: 1.12; letter-spacing: -.055em; }
  .home-intro h1 strong { color: var(--color-accent-strong); font-weight: 850; }
  .home-hero__summary { max-width: 46rem; color: var(--color-text-muted); font-size: clamp(1rem, 1.5vw, 1.2rem); }
  .home-hero__actions, .home-hero__secondary, .about-section__links { display: flex; flex-wrap: wrap; gap: var(--space-4); align-items: center; }
  .home-hero__secondary a { color: var(--color-text-muted); font-size: .86rem; font-weight: 750; text-underline-offset: .3rem; }
  .home-section { display: grid; gap: var(--space-7); border-top: 1px solid var(--color-border-strong); padding-block: var(--space-section); }
  .home-section__heading { display: grid; grid-template-columns: minmax(0, 7fr) minmax(16rem, 3fr); gap: var(--space-7); align-items: end; }
  .home-section__heading h2 { margin-top: var(--space-3); }
  .home-section__heading > p { color: var(--color-text-muted); }
  .section-marker { color: var(--color-text-muted); font: 750 .7rem/1 var(--font-mono); letter-spacing: .12em; }
  .section-marker span { color: var(--color-accent-strong); }
  .project-list { display: grid; }
  .notes-layout { display: grid; grid-template-columns: minmax(18rem, 4fr) minmax(0, 6fr); gap: clamp(2rem, 6vw, 6rem); align-items: start; }
  .featured-note { display: grid; gap: var(--space-4); border-top: .35rem solid var(--color-blog); border-bottom: 1px solid var(--color-border-strong); padding-block: var(--space-6); color: var(--color-text); text-decoration: none; }
  .featured-note h3 { max-width: 14ch; font-size: clamp(2rem, 4vw, 3.8rem); }
  .featured-note > p:not(.eyebrow) { color: var(--color-text-muted); }
  .featured-note > span { color: var(--color-blog-ink); font: 750 .72rem/1.5 var(--font-mono); }
  .featured-note:hover h3 { color: var(--color-blog-ink); }
  .recent-notes { min-width: 0; }
  .knowledge-list { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); border-top: 1px solid var(--color-border-strong); }
  .knowledge-path { display: grid; grid-template-columns: 2.5rem minmax(0, 1fr) auto; gap: var(--space-4); align-items: start; border-bottom: 1px solid var(--color-border); padding: var(--space-6) var(--space-5) var(--space-6) 0; color: var(--color-text); text-decoration: none; }
  .knowledge-path:nth-child(odd) { border-right: 1px solid var(--color-border); }
  .knowledge-path:nth-child(even) { padding-left: var(--space-5); }
  .knowledge-path > span { color: var(--path-color); font: 750 .72rem/1.4 var(--font-mono); }
  .knowledge-path h3 { font-size: clamp(1.3rem, 2.4vw, 2rem); }
  .knowledge-path p { margin-top: var(--space-2); color: var(--color-text-muted); }
  .knowledge-path b { color: var(--path-color); transition: transform var(--transition-fast); }
  .knowledge-path:hover b { transform: translateX(.3rem); }
  .knowledge-path--yellow { --path-color: #7f5200; }
  .knowledge-path--blue { --path-color: var(--color-blog-ink); }
  .knowledge-path--purple { --path-color: var(--color-experiment-ink); }
  .knowledge-path--green { --path-color: var(--color-knowledge-ink); }
  .about-section__body { display: grid; grid-template-columns: minmax(0, 7fr) minmax(16rem, 3fr); gap: var(--space-7); align-items: start; }
  .about-section__body > p { max-width: 48rem; font-size: clamp(1.25rem, 2.4vw, 2rem); line-height: 1.5; }
  .about-section__links { justify-content: flex-start; }
  @media (max-width: 64rem) {
    .home-hero__copy { grid-column: 1 / -1; }
    .notes-layout { grid-template-columns: 1fr; }
    .featured-note h3 { max-width: 22ch; }
  }
  @media (max-width: 48rem) {
    .home-intro { min-height: auto; padding-block: clamp(2.5rem, 10vw, 4.5rem); }
    .home-intro h1 { max-width: 24ch; font-size: clamp(2.3rem, 11vw, 3.8rem); line-height: 1.15; }
    .home-section { gap: var(--space-6); }
    .home-section__heading, .about-section__body { grid-template-columns: 1fr; gap: var(--space-4); }
    .knowledge-list { grid-template-columns: 1fr; }
    .knowledge-path:nth-child(odd) { border-right: 0; }
    .knowledge-path:nth-child(even) { padding-left: 0; }
  }
</style>
