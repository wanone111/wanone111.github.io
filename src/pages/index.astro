---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleRow from '../components/ArticleRow.astro';
import ContentCard from '../components/ContentCard.astro';
import ProjectShowcaseCard from '../components/ProjectShowcaseCard.astro';
import WorkbenchExplorer from '../components/WorkbenchExplorer.astro';
import { byNewest, formatDate, isPublic } from '../lib/content';

const posts = (await getCollection('blog')).filter(isPublic).sort(byNewest);
const latestPosts = posts.slice(0, 4);
const projects = (await getCollection('projects')).filter(isPublic).sort(byNewest);
const featuredProject = projects.find((entry) => entry.data.featured) ?? projects[0];
const siteUrl = Astro.site ?? new URL('https://wanone111.github.io');
const homeJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: '万志成',
    alternateName: 'Wanone',
    url: siteUrl.href,
    sameAs: ['https://github.com/wanone111'],
    knowsAbout: ['嵌入式系统', '机器人系统', 'ROS 2', 'PX4', 'FPGA', 'PYNQ', '边缘 AI'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Wanone',
    url: siteUrl.href,
    inLanguage: 'zh-CN',
    description: '个人工程档案、技术编辑部与数字知识花园。',
  },
];
---

<BaseLayout title="Wanone" description="万志成的个人工程档案、技术编辑部与数字知识花园，记录嵌入式、机器人、FPGA 与边缘 AI 实践。" contentType="首页" jsonLd={homeJsonLd}>
  <div class="home-flow">
    <section class="home-intro editorial-grid" aria-labelledby="intro-title">
      <div class="home-hero__copy">
        <p class="section-marker"><span>01</span> / INTRO</p>
        <p class="display-kicker">Embedded · Robotics · FPGA · Edge AI</p>
        <h1 id="intro-title">你好，我是<strong>万志成</strong>。我构建<span class="home-hero__topic home-hero__topic--software">嵌入式系统</span>与<span class="home-hero__topic home-hero__topic--robotics">机器人系统</span>，也在验证<span class="home-hero__topic home-hero__topic--compute">FPGA / 边缘 AI</span>。</h1>
        <p class="home-hero__summary">这里保存真实项目里的调试过程、工程判断和可复用结论。</p>
        <div class="home-hero__actions" aria-label="自我介绍相关链接">
          <a class="button" href="/projects/">查看项目</a>
          <a class="button secondary" href="/blog/">阅读文章</a>
        </div>
        <div class="home-hero__secondary" aria-label="更多个人信息">
          <a href="https://github.com/wanone111" rel="me">GitHub</a>
          <a href="/resume/">简历</a>
          <a href="/about/">关于</a>
        </div>
      </div>
      <aside class="home-intro__scope" aria-label="工程方向">
        <p>ENGINEERING SCOPE</p>
        <dl>
          <div><dt>BUILD</dt><dd>嵌入式 · 机器人</dd></div>
          <div><dt>VERIFY</dt><dd>FPGA · 边缘 AI</dd></div>
          <div><dt>PUBLISH</dt><dd>项目档案 · 工程笔记</dd></div>
        </dl>
      </aside>
    </section>

    <section class="home-section current-section" aria-labelledby="current-title">
      <div class="home-section__heading">
        <div>
          <p class="section-marker"><span>02</span> / CURRENT</p>
          <h2 id="current-title">当前工作台</h2>
        </div>
        <p>用一张工作桌保留“正在构建”的现场感；它只承担主题切换和当前研究说明。</p>
      </div>
      <div class="current-section__body editorial-grid">
        <div class="current-section__note stack">
          <p class="eyebrow">NOW VERIFYING</p>
          <h3>让公开知识保持可追溯、可构建、可验证。</h3>
          <p>当前公开系统围绕内容白名单、确定性生成和发布前质量门禁展开。新的工程方向会在真实材料准备完成后进入项目档案。</p>
          {featuredProject && <a class="text-link" href={`/projects/${featuredProject.data.slug}/`}>查看当前系统说明</a>}
        </div>
        <div class="home-hero__visual"><WorkbenchExplorer /></div>
      </div>
    </section>

    <section class="home-section systems-section" aria-labelledby="systems-title">
      <div class="home-section__heading">
        <div><p class="section-marker"><span>03</span> / SELECTED SYSTEMS</p><h2 id="systems-title">代表项目</h2></div>
        <p>只展示已有公开记录的真实系统；项目增加后沿同一结构自然扩展。</p>
      </div>
      {featuredProject ? (
        <ProjectShowcaseCard index={0} title={featuredProject.data.title} description={featuredProject.data.description} category={featuredProject.data.category} updated={formatDate(featuredProject.data.updated)} tags={featuredProject.data.tags} href={`/projects/${featuredProject.data.slug}/`} cover={featuredProject.data.cover} status={featuredProject.data.status} validation={featuredProject.data.validation} />
      ) : <div class="empty-state">暂无公开项目。</div>}
    </section>

    <section class="home-section" aria-labelledby="latest-title">
      <div class="home-section__heading">
        <div><p class="section-marker"><span>04</span> / FIELD NOTES</p><h2 id="latest-title">近期文章</h2></div>
        <a class="text-link" href="/blog/">浏览全部 {posts.length} 篇</a>
      </div>
      {latestPosts.length > 0 ? (
        <div>
          {latestPosts.map((post) => <ArticleRow href={`/blog/${post.data.slug}/`} title={post.data.title} description={post.data.description} category={post.data.category} meta={formatDate(post.data.updated)} />)}
        </div>
      ) : <div class="empty-state">暂无公开文章。</div>}
    </section>

    <section class="home-section" aria-labelledby="knowledge-title">
      <div class="home-section__heading">
        <div><p class="section-marker"><span>05</span> / KNOWLEDGE</p><h2 id="knowledge-title">知识路径</h2></div>
        <p>从短笔记到长期维护的主题文档。</p>
      </div>
      <div class="card-grid knowledge-grid">
        <ContentCard tone="yellow" href="/knowledge/embedded/" title="嵌入式与通信" description="STM32、总线协议、调试流程与工程实践。" meta="01 · Hardware" />
        <ContentCard tone="blue" href="/knowledge/robotics/" title="机器人系统" description="ROS 2、PX4、仿真与控制系统。" meta="02 · Robotics" />
        <ContentCard tone="purple" href="/knowledge/fpga-edge-ai/" title="FPGA 与边缘 AI" description="FPGA、PYNQ、视频链路与边缘推理。" meta="03 · Compute" />
        <ContentCard tone="green" href="/knowledge/linux-tools/" title="Linux 与工程工具" description="开发环境、Git、WSL 和工程化流程。" meta="04 · Tooling" />
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .home-flow { display: grid; }
  .home-intro { align-items: end; min-height: min(34rem, calc(100vh - var(--header-height))); padding-block: clamp(3rem, 7vw, 6rem); }
  .home-hero__copy { grid-column: 1 / span 8; display: grid; gap: clamp(1rem, 2.2vw, 1.7rem); }
  .home-intro h1 { max-width: 24ch; font-size: clamp(2rem, 4.4vw, 4.6rem); font-weight: 520; line-height: 1.25; letter-spacing: -.045em; }
  .home-intro h1 strong { font-weight: 850; }
  .home-hero__topic { font-weight: 800; white-space: nowrap; }
  .home-hero__topic--software { color: var(--color-blog-ink); }
  .home-hero__topic--robotics { color: var(--color-knowledge-ink); }
  .home-hero__topic--compute { color: var(--color-experiment-ink); }
  .home-hero__summary { max-width: 42rem; color: var(--color-text-muted); font-size: clamp(1rem, 1.4vw, 1.16rem); }
  .home-hero__actions { display: flex; flex-wrap: wrap; gap: var(--space-3); align-items: center; }
  .home-hero__secondary { display: flex; flex-wrap: wrap; gap: var(--space-5); }
  .home-hero__secondary a { color: var(--color-text-muted); font-size: .86rem; font-weight: 750; text-underline-offset: .3rem; }
  .home-intro__scope { grid-column: 10 / -1; border-top: 1px solid var(--color-border-strong); padding-top: var(--space-4); }
  .home-intro__scope > p, .home-intro__scope dt { color: var(--color-accent-strong); font: 750 .65rem/1.3 var(--font-mono); letter-spacing: .1em; }
  .home-intro__scope dl { display: grid; gap: var(--space-3); margin: var(--space-5) 0 0; }
  .home-intro__scope dl > div { display: grid; grid-template-columns: 4.5rem 1fr; gap: var(--space-3); }
  .home-intro__scope dd { margin: 0; color: var(--color-text-muted); font-size: .82rem; }
  .home-section { display: grid; gap: var(--space-7); border-top: 1px solid var(--color-border-strong); padding-block: var(--space-section); }
  .home-section__heading { display: grid; grid-template-columns: minmax(0, 7fr) minmax(16rem, 3fr); gap: var(--space-7); align-items: end; }
  .home-section__heading h2 { margin-top: var(--space-3); }
  .home-section__heading > p { color: var(--color-text-muted); }
  .section-marker { color: var(--color-text-muted); font: 750 .7rem/1 var(--font-mono); letter-spacing: .12em; }
  .section-marker span { color: var(--color-accent-strong); }
  .current-section__body { align-items: center; }
  .current-section__note { grid-column: 1 / span 4; }
  .current-section__note h3 { font-size: clamp(1.65rem, 3vw, 2.8rem); line-height: 1.18; }
  .current-section__note > p:last-of-type { color: var(--color-text-muted); }
  .home-hero__visual { grid-column: 6 / -1; min-width: 0; }
  @media (max-width: 64rem) {
    .home-intro { min-height: auto; }
    .home-hero__copy { grid-column: 1 / span 9; }
    .home-intro__scope { grid-column: 10 / -1; }
    .current-section__note { grid-column: 1 / span 5; }
    .home-hero__visual { grid-column: 6 / -1; }
  }
  @media (max-width: 48rem) {
    .home-intro { padding-block: clamp(2.5rem, 9vw, 4rem); }
    .home-hero__copy, .home-intro__scope, .current-section__note, .home-hero__visual { grid-column: 1 / -1; }
    .home-intro__scope { margin-top: var(--space-5); }
    .home-intro h1 { max-width: 30ch; font-size: clamp(2rem, 9.5vw, 3.1rem); line-height: 1.3; }
    .home-hero__topic { white-space: normal; }
    .home-hero__actions { align-items: stretch; }
    .home-section { gap: var(--space-6); }
    .home-section__heading { grid-template-columns: 1fr; gap: var(--space-4); }
    .home-hero__visual { margin-top: var(--space-4); }
  }
</style>
