---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import { byNewest, formatDate, isPublic } from '../../lib/content';

const posts = (await getCollection('blog')).filter(isPublic).sort(byNewest);
---

<BaseLayout title="文章归档" description="按更新时间排列的全部博客文章。">
  <div class="stack-lg">
    <PageIntro eyebrow="Archive" title="文章归档" description="按时间浏览全部公开文章。" />
    {posts.length > 0 ? (
      <ol class="archive-list">
        {posts.map((post) => <li><time datetime={post.data.updated.toISOString()}>{formatDate(post.data.updated)}</time><a href={`/blog/${post.data.slug}/`}>{post.data.title}</a></li>)}
      </ol>
    ) : <div class="empty-state">暂无已迁移文章。</div>}
  </div>
</BaseLayout>

<style>
  .archive-list { display: grid; gap: var(--space-3); margin: 0; padding: 0; list-style: none; }
  .archive-list li { display: grid; grid-template-columns: 9rem 1fr; gap: var(--space-4); border-bottom: 1px solid var(--color-border); padding-block: var(--space-3); }
  .archive-list time { color: var(--color-text-muted); }
  @media (max-width: 36rem) { .archive-list li { grid-template-columns: 1fr; gap: var(--space-1); } }
</style>
