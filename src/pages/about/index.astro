---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import { getCollection, render } from 'astro:content';
import { isPublic } from '../../lib/content';

const page = (await getCollection('pages')).find((entry) => isPublic(entry) && entry.data.slug === 'about');
const rendered = page ? await render(page) : undefined;
const Content = rendered?.Content;
---

<BaseLayout title="关于" description="关于万志成的学习背景、工程方向、项目实践与工作方法。">
  <div class="stack-lg">
    <PageIntro eyebrow="About" title="关于" description="嵌入式、机器人、FPGA 与边缘 AI 方向的项目实践和工程方法。" />
    {Content ? <section class="article-shell prose"><Content /></section> : (
      <section class="article-shell stack">
        <h2>关于我</h2>
        <p class="lede">我是万志成，主要实践方向包括嵌入式软件、机器人系统、FPGA 视频链路和边缘 AI 部署。</p>
        <h2>工程方法</h2>
        <p class="lede">我重视可复现测试、日志记录和文档沉淀，并通过构建状态、通信记录和对照实验逐步定位问题。</p>
      </section>
    )}
  </div>
</BaseLayout>
