---
interface Props { href: string; title: string; description: string; meta?: string; tone?: 'coral' | 'yellow' | 'blue' | 'purple' | 'green'; }
const { href, title, description, meta, tone = 'coral' } = Astro.props;
---

<a class={`content-card content-card--${tone}`} href={href}>
  <div class="stack">
    {meta && <span class="content-card__meta">{meta}</span>}
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
  <span class="content-card__action" aria-hidden="true">阅读</span>
</a>
