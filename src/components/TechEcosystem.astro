  @media (max-width: 62rem) { .tech-ecosystem__layout { grid-template-columns: 1fr; } .tech-map { min-height: 26rem; } .tech-results { min-height: 0; } }
  @media (max-width: 42rem) {
    .tech-ecosystem__heading { grid-template-columns: 1fr; }
    .tech-map { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-3); min-height: 0; border-radius: 0; background: none; }
    .tech-map__edge { display: none; }
    .tech-node { position: static; width: 100%; transform: none; }
    .tech-node:hover, .tech-node:focus-visible { transform: none; }
    .tech-node--center { grid-column: 1 / -1; }
    .tech-results a { grid-template-columns: 3.5rem 1fr; padding-block: var(--space-3); }
    .tech-results a > small { grid-column: 2; text-align: left; }
  }
</style>
