---
interface Props {
  index: number;
  title: string;
  description: string;
  category?: string;
  updated: string;
  tags: string[];
  href: string;
  cover?: string;
  status?: 'draft' | 'review' | 'ready' | 'published';
  validation?: string;
}
const { index, title, description, category = 'system', updated, tags, href, cover, status = 'published', validation } = Astro.props;
const statusLabels = { draft: '草稿', review: '复核中', ready: '待发布', published: '已公开' };
const categoryLabels: Record<string, string> = {
  publishing: '内容工程', embedded: '嵌入式系统', robotics: '机器人系统', fpga: 'FPGA 与边缘 AI', system: '工程系统',
};
const categoryLabel = categoryLabels[category.toLowerCase()] ?? category;
---

<article class="project-showcase">
  <div class="project-showcase__evidence">
    {cover ? (
      <img src={cover} alt={`${title} 的项目实物或验证素材`} loading="lazy" />
    ) : (
      <div class="project-record" aria-label={`${title} 的公开记录摘要`}>
        <p>PROJECT RECORD <span>{String(index + 1).padStart(2, '0')}</span></p>
        <dl>
          <div><dt>STATUS</dt><dd>{statusLabels[status]}</dd></div>
          <div><dt>UPDATED</dt><dd>{updated}</dd></div>
          <div><dt>TYPE</dt><dd>{categoryLabel}</dd></div>
          <div><dt>STACK</dt><dd>{tags.slice(0, 4).join(' · ')}</dd></div>
          {validation && <div class="project-record__wide"><dt>VALIDATION</dt><dd>{validation}</dd></div>}
        </dl>
      </div>
    )}
  </div>

  <div class="project-showcase__body stack">
    <p class="eyebrow">{String(index + 1).padStart(2, '0')} · {categoryLabel}</p>
    <h2>{title}</h2>
    <p class="lede">{description}</p>
    <div class="tag-list">{tags.map((tag) => <span class="tag">{tag}</span>)}</div>
    <a class="project-showcase__link" href={href}>打开工程档案 <span aria-hidden="true">→</span></a>
  </div>
</article>

<style>
  .project-showcase { display: grid; grid-template-columns: minmax(18rem, 5fr) minmax(20rem, 6fr); gap: clamp(2rem, 6vw, 6rem); align-items: stretch; border: 1px solid var(--color-border-strong); border-radius: var(--radius-xl); padding: clamp(1.2rem, 3vw, 2.4rem); background: var(--color-surface); box-shadow: var(--shadow-soft); }
  .project-showcase__evidence { min-height: 25rem; overflow: hidden; border-radius: var(--radius-lg); background: var(--color-surface-strong); }
  .project-showcase__evidence img { width: 100%; height: 100%; object-fit: cover; }
  .project-record { display: grid; height: 100%; align-content: space-between; gap: var(--space-7); padding: clamp(1.5rem, 4vw, 3.2rem); border-left: .45rem solid var(--color-accent); background: linear-gradient(160deg, var(--color-surface-strong), var(--color-surface)); }
  .project-record > p { display: flex; justify-content: space-between; gap: var(--space-4); color: var(--color-accent-strong); font: 750 .7rem/1.3 var(--font-mono); letter-spacing: .1em; }
  .project-record > p span { font-size: clamp(2.5rem, 6vw, 5rem); line-height: .8; }
  .project-record dl { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); margin: 0; border-top: 1px solid var(--color-border-strong); }
  .project-record dl > div { display: grid; gap: .4rem; min-height: 5.6rem; border-bottom: 1px solid var(--color-border); padding: var(--space-3) var(--space-3) var(--space-3) 0; }
  .project-record dl > div:nth-child(even) { padding-left: var(--space-3); border-left: 1px solid var(--color-border); }
  .project-record .project-record__wide { grid-column: 1 / -1; border-left: 0; padding-left: 0; }
  .project-record dt { color: var(--color-text-muted); font: 700 .6rem/1.3 var(--font-mono); letter-spacing: .08em; }
  .project-record dd { margin: 0; color: var(--color-text); font-size: .8rem; line-height: 1.45; overflow-wrap: anywhere; }
  .project-showcase__body { align-content: center; padding-block: var(--space-4); }
  .project-showcase__body h2 { max-width: 16ch; font-size: clamp(2rem, 4.5vw, 4.5rem); }
  .project-showcase__link { width: fit-content; margin-top: var(--space-3); border-bottom: 1px solid currentColor; color: var(--color-text); font-weight: 780; text-decoration: none; }
  .project-showcase__link:hover { color: var(--color-accent-strong); }
  @media (max-width: 62rem) { .project-showcase { grid-template-columns: 1fr; } .project-showcase__evidence { min-height: 20rem; } }
  @media (max-width: 36rem) { .project-showcase { padding: var(--space-3); } .project-showcase__evidence { min-height: 18rem; } .project-record { padding: var(--space-5); } .project-record dl { grid-template-columns: 1fr; } .project-record dl > div:nth-child(even) { padding-left: 0; border-left: 0; } }
</style>
