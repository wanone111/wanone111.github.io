---
interface Props {
  index: number;
  title: string;
  description: string;
  category?: string;
  updated: string;
  tags: string[];
  href: string;
  cover?: string;
  status?: 'draft' | 'review' | 'ready' | 'published';
  role?: string;
  result?: string;
  validation?: string;
}
const { index, title, description, category = 'system', updated, tags, href, cover, status = 'published', role, result, validation } = Astro.props;
const statusLabels = { draft: '草稿', review: '复核中', ready: '待发布', published: '已公开' };
const categoryLabels: Record<string, string> = {
  publishing: '内容工程', embedded: '嵌入式系统', robotics: '机器人系统', fpga: 'FPGA 与边缘 AI', system: '工程系统',
};
const categoryLabel = categoryLabels[category.toLowerCase()] ?? category;
---

<article class="project-showcase">
  <div class="project-showcase__index" aria-hidden="true">{String(index + 1).padStart(2, '0')}</div>

  <div class="project-showcase__body stack">
    <p class="eyebrow">{categoryLabel} · {statusLabels[status]} · {updated}</p>
    <h2><a href={href}>{title}</a></h2>
    <p class="lede">{description}</p>
    {role && <p class="project-showcase__role"><span>本人职责</span>{role}</p>}
    {cover && <img src={cover} alt={`${title} 的项目实物或验证素材`} loading="lazy" />}
    <div class="tag-list">{tags.map((tag) => <span class="tag">{tag}</span>)}</div>
    <a class="project-showcase__link" href={href}>打开工程档案 <span aria-hidden="true">→</span></a>
  </div>

  {(result || validation) && (
    <dl class="project-showcase__evidence" aria-label={`${title} 的结果与验证`}>
      {result && <div><dt>核心结果</dt><dd>{result}</dd></div>}
      {validation && <div><dt>验证方式</dt><dd>{validation}</dd></div>}
    </dl>
  )}
</article>

<style>
  .project-showcase { display: grid; grid-template-columns: 4rem minmax(0, 1.5fr) minmax(16rem, 1fr); gap: clamp(1.5rem, 4vw, 4rem); align-items: start; border-top: 1px solid var(--color-border-strong); padding-block: clamp(2rem, 5vw, 4rem); }
  .project-showcase:last-child { border-bottom: 1px solid var(--color-border-strong); }
  .project-showcase__index { color: var(--color-accent-strong); font: 750 clamp(1.6rem, 3vw, 2.7rem)/1 var(--font-mono); }
  .project-showcase__body h2 { max-width: 18ch; font-size: clamp(1.9rem, 4vw, 3.8rem); }
  .project-showcase__body h2 a { color: inherit; text-decoration: none; }
  .project-showcase__body h2 a:hover { color: var(--color-accent-strong); }
  .project-showcase__body img { width: 100%; max-height: 28rem; border-radius: var(--radius-md); object-fit: cover; }
  .project-showcase__role { display: grid; grid-template-columns: 5rem 1fr; gap: var(--space-3); color: var(--color-text-muted); }
  .project-showcase__role span { color: var(--color-accent-strong); font: 750 .65rem/1.6 var(--font-mono); letter-spacing: .08em; }
  .project-showcase__evidence { display: grid; gap: var(--space-5); margin: 0; border-left: 1px solid var(--color-border); padding-left: clamp(1.25rem, 3vw, 2.5rem); }
  .project-showcase__evidence > div { display: grid; gap: .45rem; }
  .project-showcase__evidence dt { color: var(--color-accent-strong); font: 750 .64rem/1.3 var(--font-mono); letter-spacing: .08em; }
  .project-showcase__evidence dd { margin: 0; color: var(--color-text); font-size: .9rem; line-height: 1.65; overflow-wrap: anywhere; }
  .project-showcase__link { width: fit-content; margin-top: var(--space-3); border-bottom: 1px solid currentColor; color: var(--color-text); font-weight: 780; text-decoration: none; }
  .project-showcase__link:hover { color: var(--color-accent-strong); }
  @media (max-width: 62rem) {
    .project-showcase { grid-template-columns: 3rem minmax(0, 1fr); }
    .project-showcase__evidence { grid-column: 2; border-left: 0; border-top: 1px solid var(--color-border); padding: var(--space-5) 0 0; }
  }
  @media (max-width: 36rem) {
    .project-showcase { grid-template-columns: 1fr; gap: var(--space-4); }
    .project-showcase__index, .project-showcase__evidence { grid-column: 1; }
    .project-showcase__role { grid-template-columns: 1fr; gap: .25rem; }
  }
</style>
