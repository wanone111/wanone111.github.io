<figure class="workbench" data-workbench>
  <div class="workbench__canvas">
    <img src="/images/brand/engineering-workbench-v2.webp" width="1536" height="1024" alt="包含台灯、电脑、书本、便签、咖啡、植物和笔记本的温暖个人工作桌插画" decoding="async" fetchpriority="high" />

    <button class="workbench__hotspot hotspot--lamp" type="button" aria-label="用台灯切换明暗主题" aria-pressed="false" data-theme-control>
      <span>台灯 · 切换主题</span>
    </button>
    <button class="workbench__hotspot hotspot--note" type="button" aria-label="便签 · 当前研究" aria-expanded="false" aria-controls="current-research" data-desk-note><span>便签 · 当前研究</span></button>

    <aside class="workbench__card" id="current-research" hidden data-desk-panel="note">
      <p class="eyebrow">Current research</p>
      <strong>让私有笔记安全、确定地长成公开知识。</strong>
      <a href="/projects/obsidian-astro-publishing/">查看进行中的系统</a>
    </aside>
  </div>
  <figcaption><span>台灯切换主题，便签打开当前研究。</span><small>2 个轻量交互</small></figcaption>
</figure>

<script>
  document.querySelectorAll<HTMLElement>('[data-workbench]').forEach((root) => {
    const note = root.querySelector<HTMLButtonElement>('[data-desk-note]');
    const panels = root.querySelectorAll<HTMLElement>('[data-desk-panel]');

    const setPanel = (name: string, control: HTMLButtonElement | null) => {
      const willOpen = control?.getAttribute('aria-expanded') !== 'true';
      note?.setAttribute('aria-expanded', String(willOpen && name === 'note'));
      panels.forEach((panel) => panel.toggleAttribute('hidden', !(willOpen && panel.dataset.deskPanel === name)));
    };
    note?.addEventListener('click', () => setPanel('note', note));
  });
</script>

<style>
  .workbench { margin: 0; }
  .workbench__canvas { position: relative; overflow: hidden; aspect-ratio: 3 / 2; border: 1px solid color-mix(in srgb, var(--color-project) 24%, var(--color-border)); border-radius: var(--radius-xl); background: var(--color-accent-soft); box-shadow: var(--shadow-card); }
  .workbench__canvas > img { width: 100%; height: 100%; object-fit: cover; }
  .workbench figcaption { display: flex; align-items: center; justify-content: space-between; gap: var(--space-3); padding: var(--space-3) var(--space-2) 0; color: var(--color-text-muted); font: 700 .7rem/1.4 var(--font-mono); }
  .workbench figcaption small { font: inherit; }
  .workbench__hotspot { position: absolute; z-index: 2; width: 2.75rem; height: 2.75rem; transform: translate(-50%, -50%); border: 0; border-radius: 50%; background: transparent; box-shadow: none; cursor: pointer; text-decoration: none; }
  .workbench__hotspot:hover, .workbench__hotspot:focus-visible, .workbench__hotspot[aria-expanded='true'], .workbench__hotspot[aria-pressed='true'] { z-index: 4; }
  .workbench__hotspot > span { position: absolute; bottom: calc(100% + .55rem); left: 50%; width: max-content; max-width: 10rem; transform: translate(-50%, .3rem); border-radius: var(--radius-pill); padding: .45rem .7rem; background: var(--color-text); color: var(--color-bg); font: 750 .68rem/1.2 var(--font-mono); opacity: 0; pointer-events: none; transition: opacity var(--transition-fast), transform var(--transition-fast); }
  .workbench__hotspot:hover > span, .workbench__hotspot:focus-visible > span, .workbench__hotspot[aria-expanded='true'] > span, .workbench__hotspot[aria-pressed='true'] > span { transform: translate(-50%, 0); opacity: 1; }
  .hotspot--lamp { left: 70%; top: 18%; }
  .hotspot--note { left: 24%; top: 78%; }
  .workbench__card { position: absolute; z-index: 3; right: var(--space-4); bottom: var(--space-4); width: min(21rem, calc(100% - 2rem)); border: 1px solid rgb(48 37 31 / .18); border-radius: var(--radius-lg); padding: var(--space-4); background: color-mix(in srgb, var(--color-bg) 94%, transparent); color: var(--color-text); box-shadow: var(--shadow-float); backdrop-filter: blur(14px); }
  .workbench__card:not([hidden]) { display: grid; gap: var(--space-2); animation: desk-card-in var(--transition-smooth) both; }
  .workbench__card strong { line-height: 1.45; }
  .workbench__card a { width: fit-content; color: var(--color-text); font-size: .82rem; font-weight: 800; }
  @keyframes desk-card-in { from { opacity: 0; transform: translateY(.6rem); } }
  @media (hover: none) {
    .workbench__hotspot { border: 1px solid rgb(255 250 241 / .78); background: rgb(48 37 31 / .42); box-shadow: 0 0 0 .22rem rgb(255 250 241 / .22); }
  }
  @media (max-width: 42rem) {
    .workbench figcaption { align-items: flex-start; flex-direction: column; }
    .workbench__hotspot > span { display: none; }
    .workbench__card { right: .7rem; bottom: .7rem; padding: var(--space-3); }
    .workbench__card .eyebrow { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .workbench__card:not([hidden]) { animation: none; }
  }
</style>
