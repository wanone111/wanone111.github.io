<dialog class="command-palette" data-command-palette aria-labelledby="command-palette-title">
  <div class="command-palette__topbar">
    <div>
      <p class="eyebrow">Quick jump</p>
      <h2 id="command-palette-title">去哪里看看？</h2>
    </div>
    <form method="dialog"><button type="submit" aria-label="关闭命令面板">Esc</button></form>
  </div>
  <label class="command-palette__search">
    <span>筛选入口</span>
    <input type="search" placeholder="输入项目、博客、知识……" autocomplete="off" data-command-search />
  </label>
  <nav aria-label="命令面板入口" data-command-list>
    <a href="/projects/" data-command="项目 project software"><strong>项目</strong><span>查看正在构建的软件与系统</span></a>
    <a href="/blog/" data-command="博客 blog writing"><strong>博客</strong><span>阅读工程笔记与实验文章</span></a>
    <a href="/knowledge/" data-command="知识 knowledge garden"><strong>知识花园</strong><span>沿公开知识路径继续探索</span></a>
    <a href="/uses/" data-command="工具 uses setup device"><strong>/uses</strong><span>打开工作区与工具说明</span></a>
    <a href="/about/" data-command="关于 about wanone"><strong>关于</strong><span>了解这个站点与它的作者</span></a>
  </nav>
  <p class="command-palette__empty" hidden data-command-empty>没有匹配入口，换一个词试试。</p>
  <p class="command-palette__hint"><kbd>↑</kbd><kbd>↓</kbd> 选择 · <kbd>Enter</kbd> 打开 · <kbd>Esc</kbd> 关闭</p>
</dialog>

<script>
  document.querySelectorAll<HTMLDialogElement>('[data-command-palette]').forEach((dialog) => {
    if (dialog.dataset.ready === 'true') return;
    dialog.dataset.ready = 'true';
    const search = dialog.querySelector<HTMLInputElement>('[data-command-search]');
    const commands = [...dialog.querySelectorAll<HTMLAnchorElement>('[data-command]')];
    const empty = dialog.querySelector<HTMLElement>('[data-command-empty]');

    const visibleCommands = () => commands.filter((command) => !command.hidden);
    const open = () => {
      if (!dialog.open) dialog.showModal();
      search?.focus();
    };
    const filter = () => {
      const query = search?.value.trim().toLocaleLowerCase('zh-CN') ?? '';
      commands.forEach((command) => {
        const haystack = `${command.dataset.command} ${command.textContent}`.toLocaleLowerCase('zh-CN');
        command.hidden = query.length > 0 && !haystack.includes(query);
      });
      empty?.toggleAttribute('hidden', visibleCommands().length > 0);
    };

    document.querySelectorAll<HTMLButtonElement>('[data-command-trigger]').forEach((trigger) => {
      trigger.addEventListener('click', open);
    });
    document.addEventListener('keydown', (event) => {
      if (dialog.open && event.key === 'Escape') {
        event.preventDefault();
        dialog.close();
      } else if ((event.metaKey || event.ctrlKey) && event.key.toLocaleLowerCase() === 'k') {
        event.preventDefault();
        dialog.open ? dialog.close() : open();
      } else if (dialog.open && (event.key === 'ArrowDown' || event.key === 'ArrowUp')) {
        const available = visibleCommands();
        if (!available.length) return;
        event.preventDefault();
        const index = available.indexOf(document.activeElement as HTMLAnchorElement);
        const next = event.key === 'ArrowDown'
          ? (index + 1) % available.length
          : (index <= 0 ? available.length - 1 : index - 1);
        available[next]?.focus();
      }
    });
    search?.addEventListener('input', filter);
    dialog.addEventListener('close', () => {
      if (search) search.value = '';
      filter();
    });
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) dialog.close();
    });
  });
</script>

<style>
  .command-palette { width: min(42rem, calc(100% - 2rem)); max-height: min(42rem, calc(100dvh - 2rem)); overflow: auto; border: 1px solid var(--color-border-strong); border-radius: var(--radius-xl); padding: var(--space-5); background: var(--color-surface); color: var(--color-text); box-shadow: var(--shadow-float); }
  .command-palette::backdrop { background: rgb(48 37 31 / .48); backdrop-filter: blur(5px); }
  .command-palette__topbar { display: flex; align-items: flex-start; justify-content: space-between; gap: var(--space-4); }
  .command-palette h2 { margin-top: .2rem; font-size: clamp(1.55rem, 4vw, 2.25rem); }
  .command-palette form button { min-width: 3rem; min-height: 2.5rem; border: 1px solid var(--color-border); border-radius: var(--radius-pill); background: var(--color-bg); color: var(--color-text-muted); font: 700 .72rem/1 var(--font-mono); cursor: pointer; }
  .command-palette__search { display: grid; gap: var(--space-2); margin-top: var(--space-5); color: var(--color-text-muted); font: 700 .7rem/1 var(--font-mono); text-transform: uppercase; }
  .command-palette__search input { width: 100%; border: 1px solid var(--color-border-strong); border-radius: var(--radius-md); padding: .9rem 1rem; background: var(--color-bg); color: var(--color-text); font: 650 1rem/1.3 var(--font-sans); }
  .command-palette nav { display: grid; gap: var(--space-2); margin-top: var(--space-4); }
  .command-palette nav a { display: grid; grid-template-columns: minmax(6rem, .35fr) 1fr; gap: var(--space-4); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: .9rem 1rem; color: var(--color-text); text-decoration: none; }
  .command-palette nav a:hover, .command-palette nav a:focus-visible { border-color: var(--color-blog); background: color-mix(in srgb, var(--color-blog) 10%, var(--color-surface)); }
  .command-palette nav span { color: var(--color-text-muted); font-size: .88rem; }
  .command-palette__empty { margin-block: var(--space-6); color: var(--color-text-muted); text-align: center; }
  .command-palette__hint { margin: var(--space-4) 0 0; color: var(--color-text-muted); font: 650 .7rem/1.4 var(--font-mono); text-align: center; }
  .command-palette kbd { border: 1px solid var(--color-border); border-radius: .3rem; padding: .12rem .3rem; background: var(--color-bg); }
  @media (max-width: 32rem) { .command-palette nav a { grid-template-columns: 1fr; gap: .15rem; } }
</style>
