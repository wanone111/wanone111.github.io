---
interface Heading { depth: number; slug: string; text: string; }
interface Props { headings: Heading[]; label?: string; }
const { headings, label = '文章目录' } = Astro.props;
const visibleHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<aside class="article-rail" aria-label={label} data-article-rail>
  <div>
    <p class="eyebrow">ON THIS PAGE</p>
    <strong>{label}</strong>
  </div>
  {visibleHeadings.length > 0 ? (
    <nav aria-label={label}>
      <ol>
        {visibleHeadings.map((heading) => (
          <li data-depth={heading.depth}><a href={`#${heading.slug}`} data-heading-link={heading.slug}>{heading.text}</a></li>
        ))}
      </ol>
    </nav>
  ) : <p class="article-rail__empty">这篇内容暂时没有分节标题。</p>}
  <div class="article-rail__progress">
    <div><span>阅读进度</span><output data-reading-percent>0%</output></div>
    <progress max="100" value="0" data-reading-progress>0%</progress>
  </div>
  <button type="button" data-back-to-top>返回顶部</button>
</aside>

<script>
  document.querySelectorAll<HTMLElement>('[data-article-rail]').forEach((rail) => {
    const progress = rail.querySelector<HTMLProgressElement>('[data-reading-progress]');
    const output = rail.querySelector<HTMLOutputElement>('[data-reading-percent]');
    const links = [...rail.querySelectorAll<HTMLAnchorElement>('[data-heading-link]')];
    const topButton = rail.querySelector<HTMLButtonElement>('[data-back-to-top]');
    let frame = 0;

    const updateProgress = () => {
      frame = 0;
      const scrollable = document.documentElement.scrollHeight - window.innerHeight;
      const value = scrollable > 0 ? Math.min(100, Math.max(0, Math.round((window.scrollY / scrollable) * 100))) : 100;
      if (progress) progress.value = value;
      if (output) output.value = `${value}%`;
    };
    const requestProgress = () => {
      if (frame) return;
      frame = window.requestAnimationFrame(updateProgress);
    };
    updateProgress();
    window.addEventListener('scroll', requestProgress, { passive: true });
    window.addEventListener('resize', requestProgress);

    if ('IntersectionObserver' in window && links.length > 0) {
      const headingById = new Map(links.map((link) => [link.dataset.headingLink ?? '', link]));
      const observer = new IntersectionObserver((entries) => {
        const visible = entries.filter((entry) => entry.isIntersecting).sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];
        if (!visible) return;
        links.forEach((link) => link.removeAttribute('aria-current'));
        headingById.get(visible.target.id)?.setAttribute('aria-current', 'location');
      }, { rootMargin: '-18% 0px -68% 0px' });
      headingById.forEach((_, id) => {
        const heading = document.getElementById(id);
        if (heading) observer.observe(heading);
      });
    }

    topButton?.addEventListener('click', () => window.scrollTo({
      top: 0,
      behavior: window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth',
    }));
  });
</script>

<style>
  .article-rail { position: sticky; top: var(--space-5); display: grid; gap: var(--space-5); color: var(--color-text-muted); font-size: .78rem; }
  .article-rail > div:first-child { display: grid; gap: .35rem; border-top: 1px solid var(--color-border-strong); padding-top: var(--space-3); }
  .article-rail > div:first-child strong { color: var(--color-text); font-size: .9rem; }
  .article-rail nav { max-height: min(44vh, 25rem); overflow: auto; }
  .article-rail ol { display: grid; gap: .2rem; margin: 0; padding: 0; list-style: none; }
  .article-rail li[data-depth='3'] { padding-left: var(--space-3); }
  .article-rail a { display: block; border-left: 2px solid var(--color-border); padding: .36rem .65rem; color: var(--color-text-muted); line-height: 1.35; text-decoration: none; }
  .article-rail a:hover, .article-rail a[aria-current='location'] { border-left-color: var(--color-accent); color: var(--color-text); }
  .article-rail__empty { color: var(--color-text-muted); }
  .article-rail__progress { display: grid; gap: .45rem; }
  .article-rail__progress > div { display: flex; justify-content: space-between; gap: var(--space-3); font: 650 .68rem/1.4 var(--font-mono); }
  .article-rail progress { width: 100%; height: .35rem; border: 0; border-radius: var(--radius-pill); background: var(--color-surface-strong); color: var(--color-accent); accent-color: var(--color-accent); }
  .article-rail progress::-webkit-progress-bar { border-radius: var(--radius-pill); background: var(--color-surface-strong); }
  .article-rail progress::-webkit-progress-value { border-radius: var(--radius-pill); background: var(--color-accent); }
  .article-rail button { width: fit-content; border: 0; border-bottom: 1px solid currentColor; padding: .25rem 0; background: transparent; color: var(--color-text); font: 700 .72rem/1.4 var(--font-mono); cursor: pointer; }
  @media (max-width: 64rem) { .article-rail { display: none; } }
  @media (prefers-reduced-motion: reduce) { .article-rail { scroll-behavior: auto; } }
</style>
