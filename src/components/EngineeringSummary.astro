---
interface Item { label: string; value?: string | null; wide?: boolean; }
interface Props { items: Item[]; label?: string; }
const { items, label = '工程摘要' } = Astro.props;
const visibleItems = items.filter((item) => item.value && item.value.trim().length > 0);
---

{visibleItems.length > 0 && (
  <dl class="engineering-summary" aria-label={label}>
    {visibleItems.map((item) => (
      <div class:list={{ 'engineering-summary__wide': item.wide }}>
        <dt>{item.label}</dt>
        <dd>{item.value}</dd>
      </div>
    ))}
  </dl>
)}

<style>
  .engineering-summary { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); border-block: 1px solid var(--color-border-strong); }
  .engineering-summary > div { display: grid; align-content: start; gap: .45rem; min-height: 6rem; border-right: 1px solid var(--color-border); padding: var(--space-4); }
  .engineering-summary > div:nth-child(4n) { border-right: 0; }
  .engineering-summary__wide { grid-column: span 2; }
  .engineering-summary dt { color: var(--color-accent-strong); font: 750 .64rem/1.3 var(--font-mono); letter-spacing: .08em; text-transform: uppercase; }
  .engineering-summary dd { margin: 0; color: var(--color-text); font-size: .88rem; line-height: 1.55; overflow-wrap: anywhere; }
  @media (max-width: 54rem) { .engineering-summary { grid-template-columns: repeat(2, minmax(0, 1fr)); } .engineering-summary > div:nth-child(odd) { border-right: 1px solid var(--color-border); } .engineering-summary > div:nth-child(even) { border-right: 0; } }
  @media (max-width: 32rem) { .engineering-summary { grid-template-columns: 1fr; } .engineering-summary > div, .engineering-summary > div:nth-child(odd) { min-height: 0; border-right: 0; border-bottom: 1px solid var(--color-border); padding-inline: 0; } .engineering-summary > div:last-child { border-bottom: 0; } .engineering-summary__wide { grid-column: auto; } }
</style>
