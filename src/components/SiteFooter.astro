---
const buildDate = new Date();
const buildLabel = new Intl.DateTimeFormat('zh-CN', {
  timeZone: 'Asia/Shanghai', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit', hour12: false,
}).format(buildDate);
---

<footer class="site-footer">
  <div class="page-shell site-footer__inner">
    <div class="stack">
      <p>© {new Date().getFullYear()} Wanone · Astro + Starlight · 内容由 Obsidian 管理</p>
      <p class="build-status" role="status"><span aria-hidden="true"></span> Build ready · <time datetime={buildDate.toISOString()}>{buildLabel} 更新</time></p>
    </div>
    <nav aria-label="页脚导航">
      <a href="/notes/">笔记</a>
      <a href="/knowledge/">知识库</a>
      <a href="/uses/">/uses</a>
      <a href="/links/">友链</a>
      <a href="/rss.xml">RSS</a>
      <a href="https://github.com/wanone111">GitHub</a>
      <button type="button" data-command-trigger>Ctrl / ⌘ K</button>
    </nav>
  </div>
</footer>

<style>
  .site-footer { margin-top: var(--space-section); border-top: 1px solid var(--color-border); background: var(--color-surface-strong); color: var(--color-text-muted); }
  .site-footer__inner { display: flex; min-height: 13rem; align-items: center; justify-content: space-between; gap: var(--space-7); padding-block: var(--space-7); font-size: .86rem; }
  nav { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: var(--space-4); }
  nav a, nav button { border: 0; padding: 0; background: transparent; color: var(--color-text); font-weight: 750; text-decoration: none; cursor: pointer; }
  nav a:hover, nav button:hover { color: var(--color-accent); }
  .build-status { display: flex; align-items: center; gap: .45rem; color: var(--color-text-muted); font: 650 .7rem/1.4 var(--font-mono); }
  .build-status > span { width: .6rem; height: .6rem; border-radius: 50%; background: var(--color-knowledge); box-shadow: 0 0 0 .24rem color-mix(in srgb, var(--color-knowledge) 18%, transparent); }
  @media (max-width: 42rem) { .site-footer__inner { align-items: flex-start; flex-direction: column; justify-content: center; } nav { justify-content: flex-start; } }
</style>
